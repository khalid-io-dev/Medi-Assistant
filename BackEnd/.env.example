# General
PROJECT_NAME="CliniQ"
VERSION="1.0.0"
ENVIRONMENT="development"

# Security
SECRET_KEY="your-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=cliniq
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ChromaDB Configuration (Persistent volume path)
CHROMA_DB_PATH=/chroma_data

# Ollama Configuration
# Local development
OLLAMA_BASE_URL=http://ollama:11434
# Production: Use Ngrok endpoint (set this in production environment)
NGROK_OLLAMA_URL=https://orthomorphic-transcriptively-maria.ngrok-free.dev
OLLAMA_MODEL=thirdeyeai/DeepSeek-R1-Distill-Qwen-7B-uncensored:Q8_0
